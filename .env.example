# ─────────────────────────────────────────────────────────────────────────────
# Скопируй этот файл в .env (или задай переменные в Vercel → Settings → Env)
# и заполни своими значениями. Файл .env в git НЕ попадает (см. .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Бренд (подставляется в промпты, тексты и UI) ──────────────────────────────
BRAND_NAME="Acme"                       # название твоего продукта/бренда
BRAND_SITE="example.com"                # сайт продукта
BRAND_FOUNDER=""                        # имя основателя для постов от 1-го лица (можно пусто)
BRAND_ONE_LINER="что это за продукт одной фразой"

# ── Threads API ───────────────────────────────────────────────────────────────
# Токен живёт 60 дней. Получается через OAuth твоего Threads-приложения.
THREADS_ACCESS_TOKEN="вставь_long_lived_token"
THREADS_USER_ID="числовой_id_твоего_аккаунта"
THREADS_USERNAME="твой-хэндл-без-собаки"   # например acme.brand

# ── Telegram (бот для одобрения постов/ответов и алертов) ─────────────────────
TELEGRAM_BOT_TOKEN="токен_от_BotFather"
TELEGRAM_CHAT_ID="твой_личный_chat_id"     # куда слать карточки на одобрение

# ── LLM (генерация и переводы через OpenRouter) ───────────────────────────────
OPENROUTER_API_KEY="sk-or-..."

# ── GitHub (очередь постов хранится как .md прямо в репо) ──────────────────────
GITHUB_TOKEN="fine-grained_PAT_с_правами_Contents_RW_на_этот_репо"
GITHUB_REPO_OWNER="your-github-org"
GITHUB_REPO_NAME="threads-bot"
GITHUB_BRANCH="main"

# ── Redis (состояние outreach/диалогов; например Upstash) ─────────────────────
# Если используешь Upstash REST:
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# ── Cron ──────────────────────────────────────────────────────────────────────
CRON_SECRET="любая_случайная_строка"       # Vercel создаёт сам при включении cron
